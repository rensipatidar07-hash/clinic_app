rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definitions & Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isClinicStaff() {
      return isSignedIn() && (
        request.auth.token.email == 'rensipatidar07@gmail.com' ||
        request.auth.token.email.endsWith('@clinicstaff.com') ||
        exists(/databases/$(database)/documents/staff/$(request.auth.uid)) ||
        // For testing/bootstrap, we can also allow any staff that has been provisioned
        exists(/databases/$(database)/documents/staff_emails/$(request.auth.token.email))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations (Pillar 2) ---

    function isValidPatient(data) {
      return data.keys().hasAll(['id', 'firstName', 'surname', 'parentName', 'nativePlace', 'phone', 'birthDate', 'gender', 'createdAt', 'updatedAt', 'creatorId'])
        && data.id is string && data.id.size() > 0 && data.id.size() <= 64
        && data.firstName is string && data.firstName.size() > 0 && data.firstName.size() <= 100
        && data.surname is string && data.surname.size() > 0 && data.surname.size() <= 100
        && data.parentName is string && data.parentName.size() > 0 && data.parentName.size() <= 100
        && data.nativePlace is string && data.nativePlace.size() > 0 && data.nativePlace.size() <= 100
        && data.phone is string && data.phone.size() >= 5 && data.phone.size() <= 20
        && data.birthDate is string
        && data.gender is string && (data.gender == 'Male' || data.gender == 'Female' || data.gender == 'Other')
        && (!data.keys().hasAny(['weight']) || data.weight is number || data.weight is string || data.weight == null)
        && data.creatorId == request.auth.uid;
    }

    function isValidVisit(data) {
      return data.keys().hasAll(['id', 'patientId', 'date', 'weight', 'height', 'temperature', 'symptoms', 'clinicalNotes', 'createdAt', 'updatedAt', 'creatorId'])
        && data.id is string && data.id.size() > 0
        && data.patientId is string && data.patientId.size() > 0
        && (data.weight is number || data.weight is string)
        && (data.height is number || data.height is string)
        && (data.temperature is number || data.temperature is string)
        && data.symptoms is list && data.symptoms.size() <= 20
        && data.clinicalNotes is string && data.clinicalNotes.size() <= 10000
        && data.creatorId == request.auth.uid;
    }

    // --- Collection Matches (Pillar 4 & 8) ---

    // Patients Collection
    match /patients/{patientId} {
      allow get: if isClinicStaff() && isValidId(patientId);
      allow list: if isClinicStaff();
      
      allow create: if isClinicStaff() && isValidId(patientId)
        && isValidPatient(incoming())
        && incoming().createdAt is string
        && incoming().updatedAt is string;

      allow update: if isClinicStaff() && isValidId(patientId)
        && isValidPatient(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().creatorId == existing().creatorId
        && incoming().updatedAt is string;

      allow delete: if isClinicStaff() && isValidId(patientId);

      // Patient Visits Subcollection
      match /visits/{visitId} {
        allow get: if isClinicStaff() && isValidId(visitId);
        allow list: if isClinicStaff();

        allow create: if isClinicStaff() && isValidId(visitId)
          && isValidVisit(incoming())
          && incoming().patientId == patientId
          && incoming().createdAt is string
          && incoming().updatedAt is string;

        allow update: if isClinicStaff() && isValidId(visitId)
          && isValidVisit(incoming())
          && incoming().createdAt == existing().createdAt
          && incoming().creatorId == existing().creatorId
          && incoming().updatedAt is string;

        allow delete: if isClinicStaff() && isValidId(visitId);
      }

      // Patient Vaccinations Tracker
      match /vaccinations/{vaccinationId} {
        allow read: if isClinicStaff();
        allow write: if isClinicStaff() && isValidId(vaccinationId);
      }

      // Patient Milestones Tracker
      match /milestones/{milestoneId} {
        allow read: if isClinicStaff();
        allow write: if isClinicStaff() && isValidId(milestoneId);
      }
    }

    // Appointments Collection
    match /appointments/{appointmentId} {
      allow get: if isClinicStaff() && isValidId(appointmentId);
      allow list: if isClinicStaff();

      allow create: if isClinicStaff() && isValidId(appointmentId)
        && incoming().id == appointmentId
        && incoming().createdAt is string
        && incoming().updatedAt is string;

      allow update: if isClinicStaff() && isValidId(appointmentId)
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt is string;

      allow delete: if isClinicStaff() && isValidId(appointmentId);
    }

    // Broadcasts Collection
    match /broadcasts/{broadcastId} {
      allow get, list: if isClinicStaff();
      allow create: if isClinicStaff() && isValidId(broadcastId)
        && incoming().id == broadcastId
        && incoming().senderId == request.auth.uid
        && incoming().createdAt is string;
      allow update, delete: if isClinicStaff() && isValidId(broadcastId);
    }

    // Clinic Settings Collection
    match /settings/{settingsId} {
      allow read: if isVerifiedUser(); // Any registered staff can read templates/webhook config
      allow write: if isClinicStaff() && isValidId(settingsId);
    }

    // Staff Registry Bootstrap (Required for Multi-device/Multi-user)
    match /staff/{staffId} {
      allow read: if isVerifiedUser();
      allow write: if isVerifiedUser() && (request.auth.token.email == 'rensipatidar07@gmail.com' || staffId == request.auth.uid);
    }

    match /staff_emails/{emailId} {
      allow read: if isVerifiedUser();
      allow write: if isVerifiedUser() && (request.auth.token.email == 'rensipatidar07@gmail.com');
    }
  }
}
