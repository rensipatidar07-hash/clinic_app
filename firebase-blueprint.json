{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Pediatric patient registration profile",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique auto-generated Patient ID (e.g. P-1001)" },
        "firstName": { "type": "string" },
        "surname": { "type": "string" },
        "parentName": { "type": "string", "description": "Father's or Mother's Name" },
        "nativePlace": { "type": "string" },
        "phone": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "gender": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "creatorId": { "type": "string" }
      },
      "required": ["id", "firstName", "surname", "parentName", "nativePlace", "phone", "birthDate", "gender", "createdAt", "updatedAt", "creatorId"]
    },
    "Visit": {
      "title": "Visit",
      "description": "Chronological clinical visit record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "weight": { "type": "number", "description": "Weight in kg" },
        "height": { "type": "number", "description": "Height in cm" },
        "headCircumference": { "type": "number", "description": "Head circumference in cm" },
        "temperature": { "type": "number", "description": "Temperature in F/C" },
        "vitalsOther": { "type": "string" },
        "symptoms": { "type": "array" },
        "symptomsOther": { "type": "string" },
        "clinicalNotes": { "type": "string" },
        "history": { "type": "string" },
        "vaccinationsGiven": { "type": "array" },
        "milestonesChecked": { "type": "array" },
        "prescriptions": { "type": "array" },
        "labReports": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "creatorId": { "type": "string" }
      },
      "required": ["id", "patientId", "date", "weight", "height", "temperature", "symptoms", "clinicalNotes", "createdAt", "updatedAt", "creatorId"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Appointment schedule details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "patientPhone": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "checked-in", "completed", "cancelled"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "creatorId": { "type": "string" }
      },
      "required": ["id", "patientId", "patientName", "patientPhone", "date", "status", "createdAt", "updatedAt", "creatorId"]
    },
    "Vaccination": {
      "title": "Vaccination",
      "description": "Vaccine tracker status for a patient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "vaccineName": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "overdue"] },
        "givenDate": { "type": "string", "format": "date" },
        "notes": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "patientId", "vaccineName", "dueDate", "status", "updatedAt"]
    },
    "Milestone": {
      "title": "Milestone",
      "description": "Milestone developmental checklist",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "milestoneName": { "type": "string" },
        "ageCategory": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "achieved", "delayed"] },
        "achievedDate": { "type": "string", "format": "date" },
        "notes": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "patientId", "milestoneName", "ageCategory", "status", "updatedAt"]
    },
    "Broadcast": {
      "title": "Broadcast",
      "description": "Broadcast SMS/WhatsApp campaigns and greetings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "recipientPhones": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "senderId": { "type": "string" }
      },
      "required": ["id", "title", "message", "recipientPhones", "createdAt", "senderId"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Clinic-wide reminder and integration settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "smsWebhook": { "type": "string" },
        "appointmentTemplate": { "type": "string" },
        "vaccineDueTemplate": { "type": "string" },
        "diwaliTemplate": { "type": "string" },
        "eidTemplate": { "type": "string" },
        "newYearTemplate": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updaterId": { "type": "string" }
      },
      "required": ["id", "smsWebhook", "appointmentTemplate", "vaccineDueTemplate", "updatedAt", "updaterId"]
    }
  },
  "firestore": {
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Root patient record"
    },
    "/patients/{patientId}/visits/{visitId}": {
      "schema": "Visit",
      "description": "Clinical visit logs for a patient"
    },
    "/patients/{patientId}/vaccinations/{vaccinationId}": {
      "schema": "Vaccination",
      "description": "Vaccinations for a patient"
    },
    "/patients/{patientId}/milestones/{milestoneId}": {
      "schema": "Milestone",
      "description": "Milestones checklist for a patient"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointments listing"
    },
    "/broadcasts/{broadcastId}": {
      "schema": "Broadcast",
      "description": "Notices and festival greeting campaigns"
    },
    "/settings/{settingsId}": {
      "schema": "Settings",
      "description": "Clinic level configuration settings"
    }
  }
}
